# Home Assistant (required for dashboard data)
HOME_ASSISTANT_URL=https://your-home-assistant.example.com
HOME_ASSISTANT_TOKEN=your-long-lived-access-token

# Optional: custom path if .env is not in the project root
# ENV_FILE=/path/to/.env

# Optional: set when running `npm run dev` behind Cloudflare Tunnel
# CLOUDFLARE_TUNNEL=1
